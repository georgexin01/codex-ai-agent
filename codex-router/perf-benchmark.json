{
  "version": "1.0",
  "updated": "2026-05-29",
  "targets": {
    "max_safe_indexed_files": 380,
    "max_knowledge_routes": 80,
    "max_missing_entries": 0,
    "max_legacy_refs": 60,
    "max_trigger_conflicts": 0,
    "max_standalone_ai_triggers": 0,
    "max_missing_trigger_targets": 0
  },
  "cases": [
    {
      "id": "boot-pulse-only",
      "type": "boot",
      "prompt": "new task startup",
      "expect_contains": [
        "Primary boot = 00_PULSE.md only",
        "00_PULSE.md"
      ],
      "expect_not_contains": [
        "00_CODEX_CUSTOM_INSTRUCTIONS_CODEX_BRIDGE.md",
        "CODEX_FULL_ACCESS_ROUTING.md"
      ]
    },
    {
      "id": "sentinel-knowledge",
      "type": "route",
      "prompt": "ai read .codex knowledge",
      "file": "00_PULSE.md",
      "expect_contains": [
        "Agent is Ready",
        "reads only this boot contract"
      ]
    },
    {
      "id": "design-app-route",
      "type": "route",
      "prompt": "ai design app",
      "file": "00_PULSE.md",
      "expect_contains": [
        "skills/design/app/SKILL.md"
      ]
    },
    {
      "id": "standalone-ai-trigger-removed",
      "type": "route",
      "prompt": "bare ai must not activate the knowledge route",
      "file": "00_PULSE.md",
      "expect_contains": [
        "never route a standalone `ai` token"
      ],
      "expect_not_contains": [
        "triggers: [\"ai\""
      ]
    },
    {
      "id": "specific-trigger-precedence",
      "type": "route",
      "prompt": "specific trigger wins over broad trigger",
      "file": "00_PULSE.md",
      "expect_contains": [
        "evaluate the longest exact trigger phrase first"
      ]
    },
    {
      "id": "telemetry-route",
      "type": "tooling",
      "prompt": "route cost telemetry exists",
      "file": "codex-router/Measure-CodexRouteTelemetry.ps1",
      "expect_contains": [
        "estimated_tokens",
        "luna-5.6-medium"
      ]
    },
    {
      "id": "gitnexus-policy-route",
      "type": "route",
      "prompt": "ai gitnexus",
      "file": "00_PULSE.md",
      "expect_contains": [
        "memories/2_governance/GITNEXUS.md"
      ]
    },
    {
      "id": "relation-autoguard-route",
      "type": "route",
      "prompt": "typed delete relation",
      "file": "memories/2_governance/artifacts/skill_path_router.md",
      "expect_contains": [
        "memories/project_notes/VBEN_RELATION_AUTOGUARD_PLAYBOOK.md"
      ]
    },
    {
      "id": "twenty-eighty-context-rule",
      "type": "principle",
      "prompt": "large context request",
      "file": "00_PULSE.md",
      "expect_contains": [
        "20/80 context compression",
        "mission-critical context verbatim"
      ]
    },
    {
      "id": "archive-noise-excluded",
      "type": "noise",
      "prompt": "normal routing should not index archive history",
      "file": "codex-router/router-config.json",
      "expect_contains": [
        "memories/archive",
        "memories/rollout_summaries"
      ],
      "manifest_forbidden_paths": [
        "archive\\\\",
        "rollout_summaries\\\\"
      ]
    },
    {
      "id": "route-integrity-rule",
      "type": "safety",
      "prompt": "merge or delete knowledge file",
      "file": "00_PULSE.md",
      "expect_contains": [
        "Route integrity is mandatory",
        "Regenerate routing"
      ]
    }
  ]
}
