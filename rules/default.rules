prefix_rule(pattern=["C:\\Windows\\System32\\WindowsPowerShell\\v1.0\\powershell.exe", "-Command", "Get-Process php -ErrorAction SilentlyContinue | Stop-Process -Force; Start-Process -FilePath php -ArgumentList @('-S','127.0.0.1:8000','-t','C:\\Users\\user\\Desktop\\VIPBillion\\website-vipbillion','index.php') -WindowStyle Hidden; Start-Sleep -Seconds 2; try { $r = Invoke-WebRequest -Uri 'http://127.0.0.1:8000/' -UseBasicParsing -ErrorAction Stop; \"$($r.StatusCode) $($r.Headers.'Content-Type')\" } catch { if ($_.Exception.Response) { $resp = $_.Exception.Response; \"$([int]$resp.StatusCode) $($resp.ContentType)\" } else { $_.Exception.Message } }"], decision="allow")
prefix_rule(pattern=["C:\\Windows\\System32\\WindowsPowerShell\\v1.0\\powershell.exe", "-Command", "$log = Join-Path $env:TEMP 'vipbillion-php.log'; if (Test-Path $log) { Remove-Item $log -Force }; Get-Process php -ErrorAction SilentlyContinue | Stop-Process -Force; Start-Process -FilePath php -ArgumentList @('-S','127.0.0.1:8000','-t','C:\\Users\\user\\Desktop\\VIPBillion\\website-vipbillion','index.php') -WindowStyle Hidden -RedirectStandardOutput $log -RedirectStandardError $log; Start-Sleep -Seconds 2; try { Invoke-WebRequest -Uri 'http://127.0.0.1:8000/' -UseBasicParsing -ErrorAction Stop | Out-Null } catch { }; Start-Sleep -Seconds 1; if (Test-Path $log) { Get-Content -Raw $log } else { 'NO_LOG' }"], decision="allow")
